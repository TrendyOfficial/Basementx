  "about": {
    "faqTitle": "Gyakori kérdések",
    "q1": {
      "title": "Honnan jön a tartalom?",
      "body": "Basement nem tárol semmilyen tartalmat. Amikor valamit meg akarsz nézni, az internetet átfésüljük a kiválasztott médiáért (A töltőképernyőn és a 'video források' fülön láthatod, hogy melyik forrást használod). Média soha nincs feltöltve Basement által, minden ezen a keresési mechanizmuson keresztül történik.",
      "section": "general"
    },
    "q2": {
      "body": "Nem lehetséges filmet vagy sorozatot kérni, Basement nem kezel semmilyen tartalmat. Az összes tartalom különböző internetes forrásokon keresztül tekinthető meg.",
      "title": "Hol tudok filmet vagy sorozatot kérni?",
      "section": "searching"
    },
    "q3": {
      "body": "A keresési eredményeinket a The Movie Database (TMDB) szolgáltatja, és megjelennek attól függetlenül, hogy bármely forráson elérhető-e a tartalom.",
      "title": "A keresési eredményekben látható a film vagy sorozat, miért nem tudom lejátszani?",
